rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Comprehensive Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getShopId() {
      return getUserData().shopId;
    }

    function getUserRole() {
      return getUserData().role;
    }

    // Role checks
    function isOwner() {
      return isSignedIn() && getUserRole() == 'owner';
    }

    // Any valid employee/staff of the shop
    function isStaffMember(shopId) {
      return isSignedIn() && getShopId() == shopId;
    }

    // Unified helper for any authenticated shop staff member
    function isAnyStaff() {
      return isSignedIn() && (getUserRole() == 'owner' || getUserRole() == 'inventory_manager' || getUserRole() == 'cashier');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || getShopId() == existing().shopId);
      allow list: if isSignedIn() && getShopId() == resource.data.shopId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().role == existing().role;
      allow update: if isOwner() && getShopId() == existing().shopId;
      allow delete: if isOwner() && getShopId() == existing().shopId && request.auth.uid != userId;
    }

    // 2. Invitations
    match /invitations/{inviteId} {
      allow get: if (inviteId.matches('.+_.+')) 
                    || (isSignedIn() && request.auth.token.email_verified == true && request.auth.token.email.toLowerCase() == inviteId);
      allow list: if isOwner() && resource.data.shopId == getShopId();
      allow create: if isOwner() && incoming().shopId == getShopId() && incoming().invitedBy == request.auth.uid;
      allow delete: if isOwner() && existing().shopId == getShopId();
    }

    // 3. Product Catalog
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock', 'category', 'unit', 'shopId']) 
        && data.keys().size() >= 6 && data.keys().size() <= 30
        && data.name is string && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.stock is number
        && data.category is string && data.category.size() <= 100
        && data.unit is string && data.unit.size() <= 50
        && data.shopId == getShopId()
        && (!data.keys().hasAny(['minStockLevel']) || (data.minStockLevel is number && data.minStockLevel >= 0));
    }

    match /products/{productId} {
      allow list: if isSignedIn() && resource.data.shopId == getShopId();
      allow get: if isStaffMember(resource.data.shopId);
      
      allow create: if isAnyStaff() 
        && isValidId(productId)
        && isValidProduct(incoming());
      
      allow update: if isAnyStaff()
        && isStaffMember(existing().shopId)
        && isValidProduct(incoming())
        && incoming().shopId == existing().shopId;
      
      allow delete: if isAnyStaff() && isStaffMember(existing().shopId);
    }

    // 4. Sales Records
    function isValidSale(data) {
      return data.keys().hasAll(['timestamp', 'totalAmount', 'shopId', 'items', 'createdBy'])
        && data.keys().size() >= 5 && data.keys().size() <= 40
        && data.timestamp is number
        && data.totalAmount is number && data.totalAmount >= 0
        && data.shopId == getShopId()
        && data.createdBy == request.auth.uid
        && data.items is list && data.items.size() <= 100
        && (!data.keys().hasAny(['dueAmount']) || (data.dueAmount is number && data.dueAmount >= 0))
        && (!data.keys().hasAny(['paymentStatus']) || (data.paymentStatus is string && (data.paymentStatus == 'paid' || data.paymentStatus == 'partially_paid' || data.paymentStatus == 'unpaid')));
    }

    match /sales/{saleId} {
      allow list: if isSignedIn() && resource.data.shopId == getShopId();
      allow get: if true; // Public view for invoicing QR code
      
      allow create: if isAnyStaff()
        && isValidId(saleId)
        && isValidSale(incoming());
      
      allow update: if isOwner() && isStaffMember(existing().shopId);
      allow delete: if isOwner() && isStaffMember(existing().shopId);
    }

    // 5. Customer Loyalty database
    match /customers/{customerId} {
      allow list: if isSignedIn() && resource.data.shopId == getShopId();
      allow get: if isStaffMember(resource.data.shopId);
      
      allow create: if isAnyStaff()
        && isValidId(customerId)
        && incoming().shopId == getShopId();
      
      allow update: if isAnyStaff()
        && isStaffMember(existing().shopId)
        && incoming().shopId == existing().shopId;
        
      allow delete: if isOwner() && isStaffMember(existing().shopId);
    }

    // 6. Shop Profile Info
    match /shops/{shopId} {
      allow get: if true; // Public access for client display QR Code
      allow write: if isOwner() && getShopId() == shopId;
    }
  }
}
