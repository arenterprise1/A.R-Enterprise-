{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with RBAC",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "inventory_manager", "cashier"] },
        "shopId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["email", "role", "shopId"]
    },
    "Product": {
      "title": "Product",
      "description": "Shop inventory item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "stock": { "type": "number" },
        "barcode": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "imageUrl": { "type": "string" },
        "shopId": { "type": "string" }
      },
      "required": ["name", "price", "stock", "shopId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Record of a completed sale",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "totalAmount": { "type": "number" },
        "discount": { "type": "number" },
        "payableAmount": { "type": "number" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "shopId": { "type": "string" },
        "createdBy": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["timestamp", "totalAmount", "shopId", "createdBy", "items"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer database for repeat purchases",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "totalSales": { "type": "number" },
        "lastPurchaseDate": { "type": "number" },
        "shopId": { "type": "string" }
      },
      "required": ["name", "phone", "shopId"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Staff invitation",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["inventory_manager", "cashier"] },
        "shopId": { "type": "string" },
        "invitedBy": { "type": "string" }
      },
      "required": ["email", "role", "shopId", "invitedBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/invitations/{email}": {
      "schema": "Invitation",
      "description": "Pending staff invitations"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory collection"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales history collection"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer management collection"
    }
  }
}
