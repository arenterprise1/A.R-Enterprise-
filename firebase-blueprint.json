{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with RBAC",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "inventory_manager", "cashier"] },
        "shopId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["email", "role", "shopId"]
    },
    "Product": {
      "title": "Product",
      "description": "Shop inventory item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "stock": { "type": "number" },
        "minStockLevel": { "type": "number", "description": "Minimum threshold for stock alerts" },
        "barcode": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "imageUrl": { "type": "string" },
        "shopId": { "type": "string" }
      },
      "required": ["name", "price", "stock", "shopId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Record of a completed sale",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "totalAmount": { "type": "number" },
        "discount": { "type": "number" },
        "payableAmount": { "type": "number" },
        "dueAmount": { "type": "number", "description": "Outstanding amount (বাকি)" },
        "paymentStatus": { "type": "string", "enum": ["paid", "partially_paid", "unpaid"] },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "shopId": { "type": "string" },
        "createdBy": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["timestamp", "totalAmount", "shopId", "createdBy", "items"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer database for repeat purchases",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "totalSales": { "type": "number" },
        "totalDue": { "type": "number", "description": "Accumulated due balance across tickets (বাকি খাতা)" },
        "lastPurchaseDate": { "type": "number" },
        "shopId": { "type": "string" }
      },
      "required": ["name", "phone", "shopId"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Staff invitation",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["inventory_manager", "cashier"] },
        "shopId": { "type": "string" },
        "invitedBy": { "type": "string" }
      },
      "required": ["role", "shopId", "invitedBy"]
    },
    "ServiceJob": {
      "title": "ServiceJob",
      "description": "Servicing/Repair Job",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "deviceName": { "type": "string" },
        "serialOrImei": { "type": "string" },
        "problemDescription": { "type": "string" },
        "repairCost": { "type": "number" },
        "advancePaid": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "repairing", "fixed", "delivered", "cancelled"] },
        "technicianNotes": { "type": "string" },
        "createdAt": { "type": "number" },
        "promisedDate": { "type": "number" }
      },
      "required": ["shopId", "customerName", "customerPhone", "deviceName", "problemDescription", "repairCost", "advancePaid", "status", "createdAt"]
    },
    "RMA": {
      "title": "RMA",
      "description": "Warranty replacement/RMA log",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "productName": { "type": "string" },
        "serialOrImei": { "type": "string" },
        "supplierName": { "type": "string" },
        "status": { "type": "string", "enum": ["sent_to_supplier", "received_from_supplier", "delivered_to_customer"] },
        "warrantyDate": { "type": "number" },
        "returnDate": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["shopId", "productName", "serialOrImei", "supplierName", "status", "warrantyDate"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "Go-down definitions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "shopId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "shopId", "createdAt"]
    },
    "WarehouseStock": {
      "title": "WarehouseStock",
      "description": "Stock levels in warehouses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "warehouseId": { "type": "string" },
        "warehouseName": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "stock": { "type": "number" },
        "shopId": { "type": "string" }
      },
      "required": ["id", "warehouseId", "warehouseName", "productId", "productName", "category", "stock", "shopId"]
    },
    "WarehouseTransfer": {
      "title": "WarehouseTransfer",
      "description": "Stock Transfer log between showrooms/go-downs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "sourceWarehouseId": { "type": "string" },
        "sourceWarehouseName": { "type": "string" },
        "destWarehouseId": { "type": "string" },
        "destWarehouseName": { "type": "string" },
        "quantity": { "type": "number" },
        "timestamp": { "type": "number" },
        "shopId": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "productId", "productName", "sourceWarehouseId", "sourceWarehouseName", "destWarehouseId", "destWarehouseName", "quantity", "timestamp", "shopId", "createdBy"]
    },
    "SMSAlert": {
      "title": "SMSAlert",
      "description": "Outbound/scheduled automatic SMS log tracer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerName": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["emi_reminder", "repair_pickup", "custom"] },
        "status": { "type": "string", "enum": ["sent", "pending", "failed"] },
        "timestamp": { "type": "number" }
      },
      "required": ["shopId", "customerPhone", "customerName", "message", "type", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/invitations/{inviteId}": {
      "schema": "Invitation",
      "description": "Pending staff invitations using secure email or phone_password keys"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory collection"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales history collection"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer management collection"
    },
    "/service_jobs/{jobId}": {
      "schema": "ServiceJob",
      "description": "Repairs/Servicing jobs collection"
    },
    "/rma/{rmaId}": {
      "schema": "RMA",
      "description": "Supplier warranty claims (RMA) tracking collection"
    },
    "/warehouses/{warehouseId}": {
      "schema": "Warehouse",
      "description": "Go-downs listing"
    },
    "/warehouse_stocks/{stockId}": {
      "schema": "WarehouseStock",
      "description": "Product stocks inside specific go-downs"
    },
    "/warehouse_transfers/{transferId}": {
      "schema": "WarehouseTransfer",
      "description": "Warehouse stock transfers auditing logs"
    },
    "/sms_alerts/{alertId}": {
      "schema": "SMSAlert",
      "description": "Outbound and automatic SMS alert notifications history"
    }
  }
}
